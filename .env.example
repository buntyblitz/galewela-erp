# Environment configuration - Development
NODE_ENV=development
PORT=3001

# Database
DB_HOST=postgres
DB_PORT=5432
DB_USER=galewela
DB_PASSWORD=dev_password_123
DB_NAME=galewela_erp
DB_POOL_MIN=2
DB_POOL_MAX=10

# Redis
REDIS_URL=redis://redis:6379
REDIS_DB=0

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

# JWT
JWT_SECRET=dev_secret_key_change_in_production_12345
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=30d

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# API Configuration
API_VERSION=v1
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX_REQUESTS=1000

# Email (SendGrid)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@galewela.com

# AWS (Optional - for local development with LocalStack)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_S3_BUCKET=galewela-erp-dev

# File Upload
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png,csv,xlsx

# Food Manufacturing Settings
DEFAULT_WAREHOUSE=WH001
DEFAULT_COST_METHOD=FIFO
FEFO_ENABLED=true
SHELF_LIFE_WARNING_DAYS=7
